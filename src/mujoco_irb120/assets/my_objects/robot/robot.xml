<mujoco>
    <!-- Root body of the robot arm with prismatic joints (XYZ slide) -->
    <body name="base_link" pos="0 0 0.035"> <!-- 0.05 for table surface and 0.035 for mounting bracket -->
        <inertial pos="-0.0036 0 0.0014" quat="0.7605 -0.0133 -0.0061 0.6491" mass="70.1294" diaginertia="1.2869 1.2236 0.9868"/>
        <geom type="mesh" mesh="base_link" name="robot0:base_link" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>
        <!-- Begin kinematic chain -->
        <body name="link_1" pos="0 0 0" gravcomp="1">
            <joint name="joint_1" type="hinge" axis="0 0 1" range="-2.87979 2.87979" limited="true" damping="0.1" frictionloss="0.01"/>
            <inertial pos="0.0006 -0.0004 0.2263" quat="0.8016 -0.0156 -0.0077 0.5977" mass="3.6488" diaginertia="0.0159 0.0157 0.0125"/>
            <geom type="mesh" mesh="link_1" name="robot0:link_1" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>

            <body name="link_2" pos="0 0 0.29" gravcomp="1">
                <joint name="joint_2" type="hinge" axis="0 1 0" range="-1.91986 1.91986" limited="true" damping="0.1" frictionloss="0.01"/>
                <inertial pos="0.0005 -0.0047 0.1061" quat="0.999978 0.00659 0.00036 -0.00049" mass="6.1585" diaginertia="0.072 0.054 0.027"/>
                <geom type="mesh" mesh="link_2" name="robot0:link_2" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>

                <body name="link_3" pos="0 0 0.27" gravcomp="1">
                    <joint name="joint_3" type="hinge" axis="0 1 0" range="-1.22173 1.91986" limited="true" damping="0.1" frictionloss="0.01"/>
                    <inertial pos="0.0349 0.0006 0.0609" quat="0.5408 0.4564 0.4341 0.5574" mass="2.7659" diaginertia="0.0161 0.0135 0.0062"/>
                    <geom type="mesh" mesh="link_3" name="robot0:link_3" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>

                    <body name="link_4" pos="0 0 0.07" gravcomp="1">
                        <joint name="joint_4" type="hinge" axis="1 0 0" range="-2.79252 2.79252" limited="true" damping="0.1" frictionloss="0.01"/>
                        <inertial pos="0.2331 0.0001 0.0016" quat="-0.005 0.716 -0.014 0.698" mass="1.5279" diaginertia="0.0053 0.0039 0.0028"/>
                        <geom type="mesh" mesh="link_4" name="robot0:link_4" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>

                        <body name="link_5" pos="0.302 0 0" gravcomp="1">
                            <joint name="joint_5" type="hinge" axis="0 1 0" range="-2.0944 2.0944" limited="true" damping="0.1" frictionloss="0.01"/>
                            <inertial pos="0.0067 0.0002 0.00004" quat="0.4995 0.4994 0.5002 0.5009" mass="0.4420" diaginertia="0.00068 0.00063 0.00028"/>
                            <geom type="mesh" mesh="link_5" name="robot0:link_5" rgba="1 0.43 0 1" contype="0" conaffinity="0"/>

                            <body name="link_6" pos="0.072 0 0" gravcomp="1">
                                <joint name="joint_6" type="hinge" axis="1 0 0" range="-3.142 3.142" limited="true" damping="0.1" frictionloss="0.01"/> <!---range +-6.98132 -->
                                <inertial pos="-0.0065 0.0002 0" quat="0.7063 0.7079 -0.0015 -0.0016" mass="0.0139" diaginertia="2.66e-6 1.52e-6 1.48e-6"/>
                                <geom type="mesh" mesh="link_6" name="robot0:link_6" rgba="0 0 0 1" contype="0" conaffinity="0"/>
                                
                                <!-- SITE: tool0 flange -->
                                <site name="site:tool0" pos="0 0 0" euler="0 0 0" size="0.01"/> <!-- rotated to match ft and adapter link -->

                                <!-- Force sensor adapter, body, etc. -->
                                <body name="ft_and_adapter_link" pos="0.041125 0 0" gravcomp="1">
                                    <geom name="robot0:ft" type="cylinder" size="0.0375 0.041125" euler="0 1.5708 0" rgba="0.5 0.5 0.5 1" mass="0.0"/>
                                    <!-- Force Sensor Site : Real robot has +y up, +x into screen, +z right (aka sensor-axial)-->
                                    <site name="site:sensor" pos="0.041125 0 0" euler="0 1.5708 1.5708" size="0.01" rgba="1 1 1 1"/>
                                    
                                    <!-- Pusher link -->
                                    <body name="pusher_link" pos="0.041125 0 0" euler="0 0 0" gravcomp="1">
                                        <!-- Visual mesh only; collision handled by explicit primitives. -->
                                        <geom name="robot0:push_rod" type="mesh" mass="0.064" euler="0 1.5708 0" mesh="pusher_link" material="robot0:gripper_mat" contype="0" conaffinity="0"/>
                                        <!-- Tip sphere collision model aligned to STL local frame.
                                            Measured mesh bounds for pusher_link.stl:
                                            - zmin = 0.000 m, zmax = 0.110 m
                                            - ball diameter = 26.5 mm  => radius = 13.25 mm
                                            - sphere center z = 0.110 - 0.01325 = 0.09675 m
                                            - friction (was) 1.5, 0.02, 0.001 but have to increase for testing as high as possible
                                        -->
                                        <geom name="robot0:push_ball_col" type="sphere" pos="0.09675 0 0" size="0.01325" mass="0.0"
                                              friction="1.5 0.0005 0.0001" solref="0.01 1" solimp="0.9 0.95 0.001"/>

                                        <!-- Try a box instead and set contact solver params -->
                                        <!-- <geom name="robot0:push_ball_col" type="box" pos="0.09675 0 0" size="0.01325 0.01325 0.01325" mass="0.0"
                                              friction="1.5 0.0005 0.0001" solref="0.01 1" solimp="0.9 0.95 0.001"/> -->
                                        
                                        <!-- Try a capsule instead -->
                                        <!-- <geom name="robot0:push_ball_col" type="capsule" pos="0.09675 0 0" euler="1.5708 0 0" size="0.01325 0.01325" mass="0.0"
                                              friction="1.5 0.005 0.0001" solref="0.01 1" solimp="0.9 0.95 0.001"/> -->

                                        <!-- Ball center site -->
                                        <site name="site:ball_center" pos="0.09675 0 0" euler="0 0 0" size="0.01" rgba="1 1 1 1"/>
                                        <!-- Pusher contact site -->
                                        <site name="site:fingertip" pos="0.11 0 0" euler="0 0 0" size="0.01" rgba="1 1 1 0"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </body>
</mujoco>
